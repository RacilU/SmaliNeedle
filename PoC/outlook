# =========================
# 메인 조회 로직
# =========================

def list_and_process_mails(start_dt: datetime):
    namespace = connect_outlook()
    inbox = get_inbox(namespace)

    items = inbox.Items

    # 오래된 메일부터 순차 조회
    items.Sort("[ReceivedTime]", False)

    # 날짜 조건은 Outlook Restrict로 먼저 줄이고,
    # 제목/발신자 조건은 Python에서 처리하는 방식이 디버깅하기 편함.
    date_filter = f"[ReceivedTime] >= '{outlook_datetime_string(start_dt)}'"
    restricted_items = items.Restrict(date_filter)

    matched_count = 0
    scanned_count = 0

    for item in restricted_items:
        if not is_mail_item(item):
            continue

        scanned_count += 1

        if not is_target_org_mail(item):
            continue

        if not is_target_subject(item):
            continue

        matched_count += 1
        process_mail(item)

    print()
    print(f"조회 완료. 스캔한 메일 수: {scanned_count}, 조건 일치 메일 수: {matched_count}")


