import re
from datetime import datetime
import win32com.client


# =========================
# 설정값
# =========================

TARGET_ORG_KEYWORDS = [
    "@example.org",       # 발신자 이메일 도메인
    "진단센터",           # 발신자 이름에 포함될 키워드
]

SUBJECT_INCLUDE = [
    "[진단결과]",
]

SUBJECT_EXCLUDE = [
    "[RE]",
    "RE:",
    "[전달]",
    "FW:",
    "FWD:",
]


# =========================
# 날짜 파싱
# =========================

def parse_start_datetime(s: str) -> datetime:
    """
    입력 예:
    260601   -> 2026-06-01 00:00
    26060114 -> 2026-06-01 14:00

    형식:
    YYMMDD 또는 YYMMDDHH
    """
    s = s.strip()

    if not re.fullmatch(r"\d{6}(\d{2})?", s):
        raise ValueError("날짜 형식은 YYMMDD 또는 YYMMDDHH 이어야 합니다. 예: 260601, 26060114")

    yy = int(s[0:2])
    mm = int(s[2:4])
    dd = int(s[4:6])
    hh = int(s[6:8]) if len(s) == 8 else 0

    year = 2000 + yy

    return datetime(year, mm, dd, hh, 0, 0)


def outlook_datetime_string(dt: datetime) -> str:
    """
    Outlook Restrict 필터에서 사용할 날짜 문자열.
    보통 MM/DD/YYYY HH:MM AM/PM 형식이 안정적입니다.
    """
    return dt.strftime("%m/%d/%Y %I:%M %p")


# =========================
# Outlook 연결
# =========================

def connect_outlook():
    outlook = win32com.client.Dispatch("Outlook.Application")
    namespace = outlook.GetNamespace("MAPI")
    return namespace


def get_inbox(namespace):
    # 6 = olFolderInbox
    return namespace.GetDefaultFolder(6)


# =========================
# 발신자 정보 처리
# =========================

def get_sender_smtp_address(mail) -> str:
    """
    Exchange/SMTP 계정 모두 어느 정도 대응하기 위한 발신자 주소 추출 함수.
    실패하면 빈 문자열 반환.
    """
    try:
        if mail.SenderEmailType == "EX":
            sender = mail.Sender
            if sender is not None:
                exch_user = sender.GetExchangeUser()
                if exch_user is not None:
                    return exch_user.PrimarySmtpAddress or ""
        return mail.SenderEmailAddress or ""
    except Exception:
        return ""


def get_sender_name(mail) -> str:
    try:
        return mail.SenderName or ""
    except Exception:
        return ""


# =========================
# 필터 조건
# =========================

def is_target_org_mail(mail) -> bool:
    sender_email = get_sender_smtp_address(mail).lower()
    sender_name = get_sender_name(mail).lower()

    for keyword in TARGET_ORG_KEYWORDS:
        k = keyword.lower()
        if k in sender_email or k in sender_name:
            return True

    return False


def is_target_subject(mail) -> bool:
    try:
        subject = mail.Subject or ""
    except Exception:
        subject = ""

    subject_upper = subject.upper()

    # 포함 조건
    for keyword in SUBJECT_INCLUDE:
        if keyword not in subject:
            return False

    # 제외 조건
    for keyword in SUBJECT_EXCLUDE:
        if keyword.upper() in subject_upper:
            return False

    return True


def is_mail_item(item) -> bool:
    """
    Outlook 폴더에는 회의 요청, 리포트 등 MailItem이 아닌 항목도 있을 수 있음.
    MailItem.Class == 43
    """
    try:
        return item.Class == 43
    except Exception:
        return False


